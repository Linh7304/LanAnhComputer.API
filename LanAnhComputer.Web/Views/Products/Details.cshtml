@model LanAnhComputer.Web.ViewModels.ProductViewModel

@{
    ViewData["Title"] = Model.ProductName;
    var isLoggedIn = Context.Session.GetString("JWT") != null;
    var images = Model.Images.Any()
        ? Model.Images
        : new List<LanAnhComputer.Web.ViewModels.ProductImageViewModel>
        {
            new()
            {
                ImageUrl = Model.ThumbnailUrl ?? Model.ImageUrl ?? "https://placehold.co/700x700/e2e8f0/64748b?text=No+Image",
                AltText = Model.ProductName,
                IsPrimary = true
            }
        };
    var mainImage = images.FirstOrDefault(x => x.IsPrimary)?.ImageUrl ?? images.First().ImageUrl;
    var inStock = Model.StockQuantity > 0;
}

<div class="container mx-auto px-4 py-8">
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
        <a href="/" class="hover:text-primary-600">Trang chu</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a href="/Products" class="hover:text-primary-600">San pham</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-800 truncate">@Model.ProductName</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mb-12">
        <div class="lg:col-span-5 space-y-4">
            <div class="w-full aspect-square bg-white rounded-2xl border border-slate-200 overflow-hidden flex items-center justify-center p-4 shadow-sm">
                <img id="mainProductImage" src="@mainImage" alt="@Model.ProductName" class="w-full h-full object-contain transition-all duration-300" />
            </div>

            <div class="grid grid-cols-5 gap-3">
                @foreach (var image in images)
                {
                    <button type="button" onclick="changeImage('@image.ImageUrl', this)" class="thumbnail-btn aspect-square bg-white rounded-xl border @(image.ImageUrl == mainImage ? "border-primary-600 border-2" : "border-slate-200") p-1 overflow-hidden hover:border-primary-500">
                        <img src="@image.ImageUrl" alt="@image.AltText" class="w-full h-full object-contain" />
                    </button>
                }
            </div>
        </div>

        <div class="lg:col-span-7">
            <div class="flex items-center gap-3 mb-3 text-xs font-semibold uppercase tracking-wider">
                @if (inStock)
                {
                    <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 rounded-full">Con hang: @Model.StockQuantity</span>
                }
                else
                {
                    <span class="px-2.5 py-1 bg-red-50 text-red-700 rounded-full">Het hang</span>
                }
                <span class="text-slate-400">|</span>
                <span class="text-slate-600">Thuong hieu: <strong class="text-slate-800">@Model.Brand</strong></span>
            </div>

            <h1 class="text-2xl lg:text-3xl font-bold text-slate-800 mb-2 leading-tight">@Model.ProductName</h1>
            <p class="text-sm text-slate-500 mb-4">SKU: @Model.ProductCode</p>

            <div class="flex items-center gap-3 mb-6">
                <div class="flex text-yellow-400">
                    @for (var i = 1; i <= 5; i++)
                    {
                        <span>@(i <= Math.Round(Model.AverageRating) ? "★" : "☆")</span>
                    }
                </div>
                <span class="text-sm font-medium text-slate-700">@Model.AverageRating.ToString("0.0")/5</span>
                <span class="text-sm text-slate-500">(@Model.TotalReviews danh gia)</span>
                <span class="text-sm text-slate-500">View: @Model.ViewCount</span>
                <span class="text-sm text-slate-500">Da ban: @Model.SoldQuantity</span>
            </div>

            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100 flex items-baseline gap-4 mb-6">
                <span class="text-3xl font-extrabold text-red-600">@Model.SalePrice.ToString("N0")đ</span>
                @if (Model.OriginalPrice.HasValue && Model.OriginalPrice.Value > Model.SalePrice)
                {
                    <span class="text-sm text-slate-400 line-through">@Model.OriginalPrice.Value.ToString("N0")đ</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ShortDescription))
            {
                <div class="mb-6 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700">
                    @Model.ShortDescription
                </div>
            }

            <div class="border-t border-slate-200 pt-6 space-y-4">
                <div class="flex items-center gap-4">
                    <span class="text-sm font-medium text-slate-700">Số lượng:</span>
                    <div class="flex items-center border border-slate-300 rounded-lg bg-white">
                        <button type="button" onclick="changeQty(-1)" class="p-2 hover:bg-slate-50"><i data-lucide="minus" class="w-4 h-4"></i></button>
                        <input type="number" id="productQuantity" value="1" min="1" max="@Math.Max(Model.StockQuantity, 1)" class="w-14 text-center border-x border-slate-300 py-1.5 focus:outline-none font-medium" />
                        <button type="button" onclick="changeQty(1)" class="p-2 hover:bg-slate-50"><i data-lucide="plus" class="w-4 h-4"></i></button>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">
                    <button onclick="submitToCart(@Model.ProductId)" @(inStock ? "" : "disabled") class="w-full py-3.5 bg-primary-600 disabled:bg-slate-300 text-white font-semibold rounded-xl hover:bg-primary-700 transition-all active:scale-95 flex items-center justify-center gap-2">
                        <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                        Thêm vào giỏ hàng
                    </button>
                    <a href="/Checkout/Index" class="w-full py-3.5 border border-primary-600 text-primary-600 font-semibold rounded-xl hover:bg-blue-50/40 transition-all active:scale-95 flex items-center justify-center gap-2 text-center">
                        <i data-lucide="zap" class="w-5 h-5"></i>
                        Mua ngay
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <section class="lg:col-span-2 space-y-8">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="bg-white border border-slate-200 rounded-xl p-6">
                    <h2 class="text-xl font-bold text-slate-800 mb-4">Mo ta san pham</h2>
                    <p class="text-slate-700 leading-7 whitespace-pre-line">@Model.Description</p>
                </div>
            }

            <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
                <div class="p-6 border-b border-slate-200">
                    <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
                        <i data-lucide="cpu" class="w-5 h-5 text-slate-600"></i>
                        Thong so ky thuat
                    </h2>
                </div>
                <div class="divide-y divide-slate-100 text-sm">
                    @if (Model.DynamicSpecifications.Any())
                    {
                        @foreach (var spec in Model.DynamicSpecifications)
                        {
                            <div class="grid grid-cols-3 p-4">
                                <div class="font-medium text-slate-500">@spec.SpecKey</div>
                                <div class="col-span-2 text-slate-800 font-medium">@spec.SpecValue</div>
                            </div>
                        }
                    }
                    else if (!string.IsNullOrWhiteSpace(Model.Specifications))
                    {
                        <div class="p-4 text-slate-700 whitespace-pre-line">@Model.Specifications</div>
                    }
                    else
                    {
                        <div class="p-4 text-slate-500">Chua co thong so.</div>
                    }
                </div>
            </div>
        </section>

        <aside class="space-y-6">
            <div class="bg-white border border-slate-200 rounded-xl p-6">
                <h2 class="text-lg font-bold text-slate-800 mb-4">Danh gia san pham</h2>
                <div class="flex items-end gap-3 mb-4">
                    <span class="text-4xl font-extrabold text-slate-900">@Model.AverageRating.ToString("0.0")</span>
                    <span class="text-sm text-slate-500 mb-1">/ 5 tu @Model.TotalReviews luot</span>
                </div>

                @if (isLoggedIn)
                {
                    <form method="post" action="/Products/Review" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.ProductId" />
                        <input type="hidden" id="ratingInput" name="rating" value="5" />
                        <div class="flex gap-1 text-3xl text-yellow-400" id="starPicker">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <button type="button" data-star="@i" class="star-btn transition-transform hover:scale-125">★</button>
                            }
                        </div>
                        <textarea name="comment" rows="3" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="Chia se cam nhan cua ban..."></textarea>
                        <button class="w-full rounded-lg bg-primary-600 px-4 py-2.5 text-white font-semibold hover:bg-primary-700">Gửi đánh giá</button>
                    </form>
                }
                else
                {
                    <button onclick="openAuthModal('login')" class="w-full rounded-lg border border-primary-600 px-4 py-2.5 text-primary-600 font-semibold hover:bg-primary-50">Dang nhap de danh gia</button>
                }
            </div>

            <div class="bg-white border border-slate-200 rounded-xl p-6">
                <h3 class="font-bold text-slate-800 mb-4">Nhan xet gan day</h3>
                <div class="space-y-4">
                    @if (!Model.ReviewsList.Any())
                    {
                        <p class="text-sm text-slate-500">Chua co danh gia.</p>
                    }
                    @foreach (var review in Model.ReviewsList)
                    {
                        <div class="border-b border-slate-100 pb-4 last:border-0">
                            <div class="flex items-center justify-between">
                                <p class="font-medium text-slate-800">@review.UserFullName</p>
                                <p class="text-xs text-slate-400">@review.CreatedAt.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="text-yellow-400 text-sm">
                                @for (var star = 1; star <= 5; star++)
                                {
                                    <span>@(star <= review.Rating ? "★" : "☆")</span>
                                }
                            </div>
                            <p class="text-sm text-slate-600 mt-2">@review.Comment</p>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        function changeQty(amount) {
            const input = document.getElementById('productQuantity');
            const max = parseInt(input.max) || 99;
            let value = parseInt(input.value) || 1;
            value = Math.min(max, Math.max(1, value + amount));
            input.value = value;
        }

        function changeImage(src, button) {
            document.getElementById('mainProductImage').src = src;
            document.querySelectorAll('.thumbnail-btn').forEach(btn => {
                btn.classList.remove('border-primary-600', 'border-2');
                btn.classList.add('border-slate-200');
            });
            button.classList.add('border-primary-600', 'border-2');
            button.classList.remove('border-slate-200');
        }

        function submitToCart(productId) {
            if (typeof addToCart === 'function') {
                addToCart(productId);
            }
        }

        document.querySelectorAll('.star-btn').forEach(btn => {
            btn.addEventListener('mouseenter', () => paintStars(parseInt(btn.dataset.star)));
            btn.addEventListener('click', () => {
                document.getElementById('ratingInput').value = btn.dataset.star;
                paintStars(parseInt(btn.dataset.star));
            });
        });

        function paintStars(value) {
            document.querySelectorAll('.star-btn').forEach(btn => {
                btn.textContent = parseInt(btn.dataset.star) <= value ? '★' : '☆';
            });
        }
    </script>
}
