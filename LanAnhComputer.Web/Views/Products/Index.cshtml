
@model LanAnhComputer.Web.ViewModels.PagedResultViewModel<LanAnhComputer.Web.ViewModels.ProductViewModel>

@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="container mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-primary-600">Trang chủ</a>

        <i data-lucide="chevron-right" class="w-4 h-4"></i>

        <span class="text-slate-800">
            Sản phẩm
        </span>
    </nav>

    <div class="flex gap-8">

        <!-- Sidebar -->
        <aside class="hidden lg:block w-64 flex-shrink-0">

            <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-24">

                <div class="flex items-center justify-between mb-6">
                    <h3 class="font-semibold text-lg text-slate-800">
                        Bộ lọc
                    </h3>

                    <button onclick="clearFilters()"
                            class="text-sm text-primary-600 hover:underline">
                        Xóa tất cả
                    </button>
                </div>

                <!-- Categories -->
                <div class="mb-6">
                    <h4 class="font-medium text-slate-800 mb-3">
                        Danh mục
                    </h4>

                    <div class="space-y-2">

                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox"
                                   class="w-4 h-4 rounded border-slate-300 text-primary-600" />

                            <span class="text-sm text-slate-600">
                                Laptop Gaming
                            </span>
                        </label>

                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox"
                                   class="w-4 h-4 rounded border-slate-300 text-primary-600" />

                            <span class="text-sm text-slate-600">
                                Laptop Văn phòng
                            </span>
                        </label>

                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox"
                                   class="w-4 h-4 rounded border-slate-300 text-primary-600" />

                            <span class="text-sm text-slate-600">
                                Linh kiện
                            </span>
                        </label>

                    </div>
                </div>

                <!-- Button -->
                <button onclick="applyFilters()"
                        class="w-full py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors">

                    Áp dụng bộ lọc

                </button>

            </div>

        </aside>

        <!-- Main -->
        <div class="flex-1">

            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">

                <div>
                    <h1 class="text-2xl font-bold text-slate-800">
                        Tất cả sản phẩm
                    </h1>
                </div>

                <!-- Sort -->
                <div class="flex items-center gap-4">

                    <select onchange="changeSort(this.value)" class="px-4 py-2 border border-slate-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-primary-500">

                        <option value="">Mặc định</option>

                        <option value="price_asc">
                            Giá: Thấp đến cao
                        </option>

                        <option value="price_desc">
                            Giá: Cao đến thấp
                        </option>

                        <option value="newest">
                            Mới nhất
                        </option>

                    </select>
                </div>

            </div>

            <!-- Product Grid -->
            <div id="product-grid"
                 class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">

                @if (Model.Items != null && Model.Items.Any())
                {
                    @foreach (var product in Model.Items)
                    {
                        @await Html.PartialAsync("_ProductCard", product)
                    }
                }
                else
                {
                    <div class="col-span-full text-center py-10">

                        <p class="text-slate-500 text-lg">
                            Không có sản phẩm nào
                        </p>

                    </div>
                }

            </div>

            <!-- Pagination -->
            <div class="flex items-center justify-center gap-2 mt-8">

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.PageNumber)
                    {
                        <button class="w-10 h-10 bg-primary-600 text-white rounded-lg font-medium">
                            @i
                        </button>
                    }
                    else
                    {
                        <a href="/Products?pageNumber=@i&sort=@Context.Request.Query["sort"]"
                           class="w-10 h-10 border border-slate-300 rounded-lg hover:bg-slate-100 font-medium flex items-center justify-center">

                            @i

                        </a>
                    }
                }

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        function clearFilters() {

            document.querySelectorAll('input[type="checkbox"], input[type="radio"]')
                .forEach(input => {
                    input.checked = false;
                });

        }

        function applyFilters() {

            alert('Đã áp dụng bộ lọc!');

        }
             function changeSort(sortValue)
        {
            window.location.href =
                `/Products?sort=${sortValue}`;
        }

    </script>
}

