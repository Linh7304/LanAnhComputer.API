@model List<LanAnhComputer.Web.ViewModels.CartItemViewModel>
@using LanAnhComputer.Web.ViewModels
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Giỏ hàng";
}
@{
    var subtotal = Model.Sum(x => x.TotalPrice);
}
<div class="container mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-primary-600">Trang chủ</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-800">Giỏ hàng</span>
    </nav>
    
    <h1 class="text-2xl font-bold text-slate-800 mb-8">Giỏ hàng của bạn</h1>
    
    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Cart Items -->
        <div class="flex-1">
            <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
                <!-- Header -->
                <div class="hidden md:grid grid-cols-12 gap-4 p-4 bg-slate-50 border-b border-slate-200 text-sm font-medium text-slate-600">
                    <div class="col-span-6">Sản phẩm</div>
                    <div class="col-span-2 text-center">Đơn giá</div>
                    <div class="col-span-2 text-center">Số lượng</div>
                    <div class="col-span-2 text-right">Thành tiền</div>
                </div>
                
                <!-- Cart Items -->
                <div id="cart-items">
                    @foreach (var item in Model)
                    {
                        <div class="cart-item grid grid-cols-1 md:grid-cols-12 gap-4 p-4 border-b border-slate-100 last:border-0" data-id="@item.ProductId">
                            <!-- Product -->
                            <div class="col-span-6 flex gap-4">
                                <div class="w-24 h-24 bg-slate-100 rounded-lg overflow-hidden flex-shrink-0">
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductName"
                                         class="w-full h-full object-cover"
                                         onerror="this.onerror=null;this.src='/images/no-image.png';" />
                                </div>
                                <div class="flex-1">
                                    <h3 class="font-medium text-slate-800 mb-1 line-clamp-2">@item.ProductName</h3>
                                    <p class="text-sm text-slate-500 mb-2">SKU: LAC-00@item.ProductId</p>
                                    <button onclick="removeItem(@item.ProductId)" class="text-sm text-red-500 hover:text-red-600 flex items-center gap-1">
                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        Xóa
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Price -->
                            <div class="col-span-2 flex items-center justify-center">
                                <span class="text-slate-800 font-medium">@item.Price.ToString("N0")đ</span>
                            </div>
                            
                            <!-- Quantity -->
                            <div class="col-span-2 flex items-center justify-center">
                                <div class="flex items-center border border-slate-300 rounded-lg">
                                    <button onclick="updateQuantity(@item.ProductId, -1)" class="p-2 hover:bg-slate-100 transition-colors">
                                        <i data-lucide="minus" class="w-4 h-4"></i>
                                    </button>
                                    <input type="number" value="@item.Quantity" min="1"
                                           class="w-12 text-center border-x border-slate-300 py-2 focus:outline-none"
                                           onchange="updateQuantityInput(@item.ProductId, this.value)" />
                                    <button onclick="updateQuantity(@item.ProductId, 1)" class="p-2 hover:bg-slate-100 transition-colors">
                                        <i data-lucide="plus" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Subtotal -->
                            <div class="col-span-2 flex items-center justify-end">
                                <span class="text-red-600 font-bold">@item.TotalPrice.ToString("N0")đ</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <!-- Continue Shopping -->
            <div class="mt-4">
                <a href="/Products/Index" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-medium">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    Tiếp tục mua sắm
                </a>
            </div>
        </div>
        
        <!-- Order Summary -->
        <div class="lg:w-96">
            <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-24">
                <h2 class="text-lg font-semibold text-slate-800 mb-6">Tóm tắt đơn hàng</h2>
                
                <!-- Coupon -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Mã giảm giá</label>
                    <div class="flex gap-2">
                        <input type="text"
                               placeholder="Nhập mã giảm giá"
                               class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                        <button class="px-4 py-2 bg-slate-800 text-white rounded-lg hover:bg-slate-700 transition-colors">
                            Áp dụng
                        </button>
                    </div>
                </div>
                
                <!-- Totals -->
                <div class="space-y-3 mb-6">
                    <div class="flex justify-between text-slate-600">
                        <span>Tạm tính</span>
                        <span id="subtotal"> @subtotal.ToString("N0")đ</span>
                    </div>
                    <div class="flex justify-between text-slate-600">
                        <span>Giảm giá</span>
                        <span class="text-emerald-600">-0đ</span>
                    </div>
                    <div class="flex justify-between text-slate-600">
                        <span>Phí vận chuyển</span>
                        <span class="text-emerald-600">Miễn phí</span>
                    </div>
                    <div class="border-t border-slate-200 pt-3 flex justify-between">
                        <span class="text-lg font-semibold text-slate-800">Tổng cộng</span>
                        <span id="total" class="text-xl font-bold text-red-600">
                            @subtotal.ToString("N0")đ
                        </span>
                    </div>
                </div>
                
                <!-- VAT Note -->
                <p class="text-xs text-slate-500 mb-6">(Đã bao gồm VAT nếu có)</p>
                
                <!-- Checkout Button -->
                <a href="/Checkout/Index"
                       class="block w-full py-3 bg-primary-600 text-white text-center font-semibold rounded-lg hover:bg-primary-700 transition-colors">
                    Tiến hành thanh toán
                </a>
                
                <!-- Payment Methods -->
                <div class="mt-6 pt-6 border-t border-slate-200">
                    <p class="text-sm text-slate-600 mb-3">Chấp nhận thanh toán</p>
                    <div class="flex gap-2">
                        <div class="w-12 h-8 bg-slate-100 rounded flex items-center justify-center text-xs font-medium text-slate-500">VISA</div>
                        <div class="w-12 h-8 bg-slate-100 rounded flex items-center justify-center text-xs font-medium text-slate-500">MC</div>
                        <div class="w-12 h-8 bg-slate-100 rounded flex items-center justify-center text-xs font-medium text-slate-500">ATM</div>
                        <div class="w-12 h-8 bg-slate-100 rounded flex items-center justify-center text-xs font-medium text-slate-500">COD</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {

    <script>

        const token = "@Context.Session.GetString("JWT")";

        function removeItem(id) {

            fetch(`https://localhost:7132/api/cart/remove/${id}`, {

                method: "DELETE",

                headers: {
                    "Authorization": `Bearer ${token}`
                }

            })
                    .then(async response => {

            if (response.ok) {
                location.reload();
                return;
            }

            const errorMessage = await response.text();

            alert(errorMessage);
        });
        }

        function updateQuantity(id, delta) {

            const input = document.querySelector(
                `.cart-item[data-id="${id}"] input`
            );

            let newQty = parseInt(input.value) + delta;

            if (newQty < 1)
                newQty = 1;

            fetch(`https://localhost:7132/api/cart/update`, {

                method: "PUT",

                headers: {
                    "Content-Type": "application/json",
                    "Authorization": `Bearer ${token}`
                },

                body: JSON.stringify({
                    productId: id,
                    quantity: newQty
                })

            })
            .then(response => {

                if (response.ok) {
                    location.reload();
                }
                else {
                    alert("Có lỗi xảy ra");
                }
            });
        }

        function updateQuantityInput(id, value) {

            let qty = parseInt(value);

            if (qty < 1)
                qty = 1;

            fetch(`https://localhost:7132/api/cart/update`, {

                method: "PUT",

                headers: {
                    "Content-Type": "application/json",
                    "Authorization": `Bearer ${token}`
                },

                body: JSON.stringify({
                    productId: id,
                    quantity: qty
                })

            })
            .then(response => {

                if (response.ok) {
                    location.reload();
                }
                else {
                    alert("Có lỗi xảy ra");
                }
            });
        }

    </script>
}