@using LanAnhComputer.Web.Models
@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<form asp-controller="Checkout" asp-action="PlaceOrder" method="post">
    <div class="container mx-auto px-4 py-8">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
            <a href="/" class="hover:text-primary-600">Trang chủ</a>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
            <a href="/gio-hang" class="hover:text-primary-600">Giỏ hàng</a>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
            <span class="text-slate-800">Thanh toán</span>
        </nav>

        <div class="flex items-center justify-center gap-4 mb-8">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-medium">1</div>
                <span class="text-sm font-medium text-primary-600">Thông tin</span>
            </div>
            <div class="w-16 h-0.5 bg-slate-300"></div>
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-slate-300 text-slate-600 flex items-center justify-center text-sm font-medium">2</div>
                <span class="text-sm text-slate-500">Thanh toán</span>
            </div>
            <div class="w-16 h-0.5 bg-slate-300"></div>
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-slate-300 text-slate-600 flex items-center justify-center text-sm font-medium">3</div>
                <span class="text-sm text-slate-500">Hoàn tất</span>
            </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
            <div class="flex-1">
                <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
                    <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
                        <i data-lucide="user" class="w-5 h-5 text-primary-600"></i>
                        Thông tin khách hàng
                    </h2>

                    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mb-4"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="FullName" class="block text-sm font-medium text-slate-700 mb-2">Họ và tên *</label>
                            <input asp-for="FullName"
                                   type="text"
                                   placeholder="Nguyễn Văn A"
                                   class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Phone" class="block text-sm font-medium text-slate-700 mb-2">Số điện thoại *</label>
                            <input asp-for="Phone"
                                   type="tel"
                                   placeholder="0901234567"
                                   class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-2">Email</label>
                            <input asp-for="Email"
                                   type="email"
                                   placeholder="email@example.com"
                                   class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
                    <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
                        <i data-lucide="map-pin" class="w-5 h-5 text-primary-600"></i>
                        Địa chỉ nhận hàng
                    </h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Province" class="block text-sm font-medium text-slate-700 mb-2">Tỉnh/Thành phố *</label>
                            <select asp-for="Province" id="province" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                                <option value="">Chọn Tỉnh/Thành phố</option>
                            </select>
                            <span asp-validation-for="Province" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Ward" class="block text-sm font-medium text-slate-700 mb-2">Phường/Xã *</label>
                            <select asp-for="Ward" id="ward" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                                <option value="">Chọn Phường/Xã</option>
                            </select>
                            <span asp-validation-for="Ward" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Address" class="block text-sm font-medium text-slate-700 mb-2">Số nhà, tên đường *</label>
                            <input asp-for="Address"
                                   type="text"
                                   placeholder="123 Nguyễn Văn Linh"
                                   class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            <span asp-validation-for="Address" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Note" class="block text-sm font-medium text-slate-700 mb-2">Ghi chú</label>
                            <textarea asp-for="Note"
                                      placeholder="Ghi chú về đơn hàng, ví dụ: thời gian hay địa điểm giao hàng chi tiết hơn."
                                      rows="3"
                                      class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-slate-200 p-6">
                    <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
                        <i data-lucide="credit-card" class="w-5 h-5 text-primary-600"></i>
                        Phương thức thanh toán
                    </h2>

                    <div class="space-y-3">
                        <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                            <input asp-for="PaymentMethod" type="radio" value="COD" class="w-4 h-4 text-primary-600" />
                            <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                                <i data-lucide="banknote" class="w-6 h-6 text-emerald-600"></i>
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-slate-800">Thanh toán khi nhận hàng (COD)</p>
                                <p class="text-sm text-slate-500">Thanh toán bằng tiền mặt khi nhận hàng</p>
                            </div>
                        </label>

                        <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                            <input asp-for="PaymentMethod" type="radio" value="BankTransfer" class="w-4 h-4 text-primary-600" />
                            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                                <i data-lucide="building-2" class="w-6 h-6 text-blue-600"></i>
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-slate-800">Chuyển khoản ngân hàng</p>
                                <p class="text-sm text-slate-500">Chuyển khoản qua tài khoản ngân hàng</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                            <input asp-for="PaymentMethod" type="radio" value="EWallet" class="w-4 h-4 text-primary-600" />
                            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center">
                                <i data-lucide="wallet" class="w-6 h-6 text-orange-600"></i>
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-slate-800">Ví điện tử</p>
                                <p class="text-sm text-slate-500">MoMo, ZaloPay, VNPay</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="lg:w-96">
                <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-24">
                    <h2 class="text-lg font-semibold text-slate-800 mb-6">Đơn hàng của bạn</h2>

                    <div class="space-y-4 mb-6 max-h-64 overflow-y-auto">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="flex gap-3">
                                <div class="w-16 h-16 bg-slate-100 rounded-lg flex-shrink-0 overflow-hidden">
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductName"
                                         class="w-full h-full object-cover"
                                         onerror="this.src='/images/no-image.png'" />
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-slate-800 truncate">@item.ProductName</p>
                                    <p class="text-sm text-slate-500">SL: @item.Quantity</p>
                                    <p class="text-sm font-semibold text-red-600">@item.TotalPrice.ToString("N0")đ</p>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="space-y-3 mb-6 pt-6 border-t border-slate-200">
                        <div class="flex justify-between text-slate-600">
                            <span>Tạm tính</span>
                            <span>@Model.SubTotal.ToString("N0")đ</span>
                        </div>
                        <div class="flex justify-between text-slate-600">
                            <span>Phí vận chuyển</span>
                            <span class="text-emerald-600">Miễn phí</span>
                        </div>
                        <div class="border-t border-slate-200 pt-3 flex justify-between">
                            <span class="text-lg font-semibold text-slate-800">Tổng cộng</span>
                            <span class="text-xl font-bold text-red-600">@Model.SubTotal.ToString("N0")đ</span>
                        </div>
                    </div>

                    <button type="submit" class="w-full py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors flex items-center justify-center gap-2">
                        <i data-lucide="lock" class="w-4 h-4"></i>
                        Đặt hàng
                    </button>

                    <p class="text-xs text-slate-500 text-center mt-4 flex items-center justify-center gap-1">
                        <i data-lucide="shield-check" class="w-4 h-4 text-emerald-500"></i>
                        Thanh toán an toàn và bảo mật
                    </p>
                </div>
            </div>
        </div>
    </div>
</form>

<script src="/js/location.js"></script>
<script>
    const codRadio = document.querySelector('input[value="COD"]');
    const bankRadio = document.querySelector('input[value="BankTransfer"]');
    const ewalletRadio = document.querySelector('input[value="EWallet"]');

    const submitBtn = document.querySelector("button[type='submit']");

    function updateUI() {
    if (codRadio.checked) {
    submitBtn.innerText = "Đặt hàng (COD)";
    }

    if (bankRadio.checked || ewalletRadio.checked) {
    submitBtn.innerText = "Thanh toán ngay qua PayOS";
    }
    }

    codRadio.addEventListener("change", updateUI);
    bankRadio.addEventListener("change", updateUI);
    ewalletRadio.addEventListener("change", updateUI);

    updateUI();
</script>