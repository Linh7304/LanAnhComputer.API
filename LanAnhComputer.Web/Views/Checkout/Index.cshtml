@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-primary-600">Trang chủ</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a href="/gio-hang" class="hover:text-primary-600">Giỏ hàng</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-800">Thanh toán</span>
    </nav>
    
    <!-- Progress Steps -->
    <div class="flex items-center justify-center gap-4 mb-8">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-medium">1</div>
            <span class="text-sm font-medium text-primary-600">Thông tin</span>
        </div>
        <div class="w-16 h-0.5 bg-slate-300"></div>
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-slate-300 text-slate-600 flex items-center justify-center text-sm font-medium">2</div>
            <span class="text-sm text-slate-500">Thanh toán</span>
        </div>
        <div class="w-16 h-0.5 bg-slate-300"></div>
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-slate-300 text-slate-600 flex items-center justify-center text-sm font-medium">3</div>
            <span class="text-sm text-slate-500">Hoàn tất</span>
        </div>
    </div>
    
    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Checkout Form -->
        <div class="flex-1">
            <!-- Customer Info -->
            <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i data-lucide="user" class="w-5 h-5 text-primary-600"></i>
                    Thông tin khách hàng
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Họ và tên *</label>
                        <input type="text"
                               placeholder="Nguyễn Văn A"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Số điện thoại *</label>
                        <input type="tel"
                               placeholder="0901234567"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-2">Email</label>
                        <input type="email"
                               placeholder="email@example.com"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                    </div>
                </div>
            </div>
            
            <!-- Shipping Address -->
            <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i data-lucide="map-pin" class="w-5 h-5 text-primary-600"></i>
                    Địa chỉ nhận hàng
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Tỉnh/Thành phố *</label>
                        <select class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                            <option value="">Chọn Tỉnh/Thành phố</option>
                            <option>TP. Hồ Chí Minh</option>
                            <option>Hà Nội</option>
                            <option>Đà Nẵng</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Quận/Huyện *</label>
                        <select class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                            <option value="">Chọn Quận/Huyện</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Phường/Xã *</label>
                        <select class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                            <option value="">Chọn Phường/Xã</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Số nhà, tên đường *</label>
                        <input type="text"
                               placeholder="123 Nguyễn Văn Linh"
                               class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-2">Ghi chú</label>
                        <textarea placeholder="Ghi chú về đơn hàng, ví dụ: thời gian hay địa điểm giao hàng chi tiết hơn."
                                  rows="3"
                                  class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
                    </div>
                </div>
            </div>
            
            <!-- Payment Method -->
            <div class="bg-white rounded-xl border border-slate-200 p-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i data-lucide="credit-card" class="w-5 h-5 text-primary-600"></i>
                    Phương thức thanh toán
                </h2>
                
                <div class="space-y-3">
                    <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                        <input type="radio" name="payment" value="cod" checked class="w-4 h-4 text-primary-600" />
                        <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                            <i data-lucide="banknote" class="w-6 h-6 text-emerald-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="font-medium text-slate-800">Thanh toán khi nhận hàng (COD)</p>
                            <p class="text-sm text-slate-500">Thanh toán bằng tiền mặt khi nhận hàng</p>
                        </div>
                    </label>
                    
                    <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                        <input type="radio" name="payment" value="bank" class="w-4 h-4 text-primary-600" />
                        <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                            <i data-lucide="building-2" class="w-6 h-6 text-blue-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="font-medium text-slate-800">Chuyển khoản ngân hàng</p>
                            <p class="text-sm text-slate-500">Chuyển khoản qua tài khoản ngân hàng</p>
                        </div>
                    </label>
                    
                    <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                        <input type="radio" name="payment" value="card" class="w-4 h-4 text-primary-600" />
                        <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
                            <i data-lucide="credit-card" class="w-6 h-6 text-purple-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="font-medium text-slate-800">Thẻ tín dụng / Ghi nợ</p>
                            <p class="text-sm text-slate-500">Visa, Mastercard, JCB</p>
                        </div>
                    </label>
                    
                    <label class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-primary-500 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                        <input type="radio" name="payment" value="ewallet" class="w-4 h-4 text-primary-600" />
                        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center">
                            <i data-lucide="wallet" class="w-6 h-6 text-orange-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="font-medium text-slate-800">Ví điện tử</p>
                            <p class="text-sm text-slate-500">MoMo, ZaloPay, VNPay</p>
                        </div>
                    </label>
                </div>
            </div>
        </div>
        
        <!-- Order Summary -->
        <div class="lg:w-96">
            <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-24">
                <h2 class="text-lg font-semibold text-slate-800 mb-6">Đơn hàng của bạn</h2>
                
                <!-- Items -->
                <div class="space-y-4 mb-6 max-h-64 overflow-y-auto">
                    @{
                        var items = new[] {
                            new { Name = "ASUS ROG Strix G15", Price = 32990000, Qty = 1 },
                            new { Name = "Chuột Gaming Logitech G502 X Plus", Price = 3290000, Qty = 2 },
                            new { Name = "Bàn phím cơ Corsair K70 RGB Pro", Price = 4590000, Qty = 1 }
                        };
                    }
                    
                    @foreach (var item in items)
                    {
                        <div class="flex gap-3">
                            <div class="w-16 h-16 bg-slate-100 rounded-lg flex-shrink-0"></div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-slate-800 truncate">@item.Name</p>
                                <p class="text-sm text-slate-500">SL: @item.Qty</p>
                                <p class="text-sm font-semibold text-red-600">@item.Price.ToString("N0")đ</p>
                            </div>
                        </div>
                    }
                </div>
                
                <!-- Totals -->
                <div class="space-y-3 mb-6 pt-6 border-t border-slate-200">
                    <div class="flex justify-between text-slate-600">
                        <span>Tạm tính</span>
                        <span>44.160.000đ</span>
                    </div>
                    <div class="flex justify-between text-slate-600">
                        <span>Phí vận chuyển</span>
                        <span class="text-emerald-600">Miễn phí</span>
                    </div>
                    <div class="border-t border-slate-200 pt-3 flex justify-between">
                        <span class="text-lg font-semibold text-slate-800">Tổng cộng</span>
                        <span class="text-xl font-bold text-red-600">44.160.000đ</span>
                    </div>
                </div>
                
                <!-- Terms -->
                <label class="flex items-start gap-2 mb-6 cursor-pointer">
                    <input type="checkbox" class="mt-1 w-4 h-4 rounded border-slate-300 text-primary-600" />
                    <span class="text-sm text-slate-600">
                        Tôi đã đọc và đồng ý với
                        <a href="#" class="text-primary-600 hover:underline">Điều khoản dịch vụ</a> và
                        <a href="#" class="text-primary-600 hover:underline">Chính sách bảo mật</a>
                    </span>
                </label>
                
                <!-- Submit Button -->
                <button type="submit"
                        class="w-full py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors flex items-center justify-center gap-2">
                    <i data-lucide="lock" class="w-4 h-4"></i>
                    Đặt hàng
                </button>
                
                <!-- Security Note -->
                <p class="text-xs text-slate-500 text-center mt-4 flex items-center justify-center gap-1">
                    <i data-lucide="shield-check" class="w-4 h-4 text-emerald-500"></i>
                    Thanh toán an toàn và bảo mật
                </p>
            </div>
        </div>
    </div>
</div>
