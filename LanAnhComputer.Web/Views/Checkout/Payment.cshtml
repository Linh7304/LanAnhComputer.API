@model LanAnhComputer.Web.Models.PayOSResponseViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mx-auto px-4 py-10">

    <div class="max-w-3xl mx-auto">

        <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">

            <div class="text-center mb-8">

                <div class="w-20 h-20 mx-auto rounded-full bg-blue-100 flex items-center justify-center mb-4">
                    <i data-lucide="qr-code"
                       class="w-10 h-10 text-blue-600"></i>
                </div>

                <h1 class="text-3xl font-bold text-slate-800 mb-2">
                    Thanh toán đơn hàng
                </h1>

                <p class="text-slate-500">
                    Vui lòng quét mã QR để hoàn tất thanh toán
                </p>

            </div>

            <div class="grid md:grid-cols-2 gap-8">

                <!-- QR -->
                <div class="flex justify-center">
                    <img src="@Model.QrCode"
                         class="w-72 h-72 border rounded-2xl p-3 bg-white" />
                   
                </div>

                <div class="space-y-4">

                    <div class="p-4 rounded-xl bg-slate-50 border">

                        <p class="text-sm text-slate-500 mb-1">
                            Mã thanh toán
                        </p>

                        <p class="font-semibold text-lg">
                            @Model.OrderCode
                        </p>

                    </div>

                    <div class="p-4 rounded-xl bg-red-50 border border-red-100">

                        <p class="text-sm text-slate-500 mb-1">
                            Số tiền
                        </p>

                        <p class="font-bold text-2xl text-red-600">
                            @Model.Amount.ToString("N0")đ
                        </p>

                    </div>

                    <a href="@Model.CheckoutUrl"
                       target="_blank"
                       class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 rounded-xl transition">

                        Mở trang thanh toán PayOS

                    </a>

                </div>

            </div>

            <div class="mt-8 text-center text-sm text-slate-500">
                Hệ thống sẽ tự động xác nhận sau khi thanh toán thành công
            </div>

        </div>

    </div>

</div>

<script>
    setInterval(async () => {

        const response = await fetch('/Orders/CheckPaymentStatus?orderId=@Model.OrderId');

        const result = await response.json();

        if (result.success) {
            window.location.href = '/Checkout/Complete';
        }

    }, 3000);
</script>