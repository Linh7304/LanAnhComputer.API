<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thanh toán - Lan Anh Computer</title>
    <!-- Tích hợp Tailwind CSS -->
    <script src="https://jsdelivr.net"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: {
        600: '#2563eb', /* Màu xanh giống trang giỏ hàng của bạn */
        700: '#1d4ed8',
        }
        }
        }
        }
        }
    </script>
    <style>
        .payment-radio:checked ~ .payment-box {
        border-color: #2563eb;
        background-color: rgba(37, 99, 235, 0.03);
        }
    </style>
</head>
<body class="bg-slate-50 font-sans antialiased text-slate-800">

    <div class="container mx-auto px-4 py-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
            <a href="#" class="hover:text-primary-600">Trang chủ</a>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
            <a href="#" class="hover:text-primary-600">Giỏ hàng</a>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
            <span class="text-slate-800">Thanh toán</span>
        </nav>

        <h1 class="text-2xl font-bold text-slate-800 mb-8">Thông tin đặt hàng</h1>

        <form onsubmit="event.preventDefault(); alert('Đặt hàng thành công!');">
            <div class="flex flex-col lg:flex-row gap-8">

                <!-- Cột trái: Thông tin giao hàng & Thanh toán -->
                <div class="flex-1 space-y-6">

                    <!-- Khối thông tin khách hàng -->
                    <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                        <h2 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
                            <i data-lucide="map-pin" class="w-5 h-5 text-slate-600"></i>
                            Thông tin giao hàng
                        </h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-slate-700 mb-1">Họ và tên</label>
                                <input type="text" required placeholder="Nguyễn Văn A"
                                       class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Số điện thoại</label>
                                <input type="tel" required placeholder="0912345678"
                                       class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Email (Không bắt buộc)</label>
                                <input type="email" placeholder="nguyenvana@gmail.com"
                                       class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-slate-700 mb-1">Địa chỉ nhận hàng</label>
                                <input type="text" required placeholder="Số 123, Đường Trần Phú, Quận Hà Đông, Hà Nội"
                                       class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-slate-700 mb-1">Ghi chú đơn hàng</label>
                                <textarea rows="3" placeholder="Giao giờ hành chính, gọi trước khi giao 15 phút..."
                                          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Khối phương thức thanh toán -->
                    <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                        <h2 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
                            <i data-lucide="credit-card" class="w-5 h-5 text-slate-600"></i>
                            Phương thức thanh toán
                        </h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <!-- COD -->
                            <label class="relative block cursor-pointer">
                                <input type="radio" name="PaymentMethod" value="COD" checked class="peer sr-only payment-radio" />
                                <div class="payment-box p-4 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors flex items-start gap-3">
                                    <div class="w-4 h-4 rounded-full border border-slate-300 flex items-center justify-center mt-0.5"></div>
                                    <div>
                                        <span class="block font-medium text-slate-800 text-sm">Thanh toán khi nhận hàng (COD)</span>
                                        <span class="block text-xs text-slate-500 mt-0.5">Thanh toán bằng tiền mặt khi nhận hàng</span>
                                    </div>
                                </div>
                            </label>

                            <!-- Chuyển khoản -->
                            <label class="relative block cursor-pointer">
                                <input type="radio" name="PaymentMethod" value="BankTransfer" class="peer sr-only payment-radio" />
                                <div class="payment-box p-4 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors flex items-start gap-3">
                                    <div class="w-4 h-4 rounded-full border border-slate-300 flex items-center justify-center mt-0.5"></div>
                                    <div>
                                        <span class="block font-medium text-slate-800 text-sm">Chuyển khoản ngân hàng</span>
                                        <span class="block text-xs text-slate-500 mt-0.5">Qua mã QR hoặc số tài khoản ngân hàng</span>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Cột phải: Tóm tắt đơn hàng thu nhỏ -->
                <div class="lg:w-96">
                    <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-24 shadow-sm">
                        <h2 class="text-lg font-semibold text-slate-800 mb-4">Đơn hàng của bạn</h2>

                        <!-- Danh sách sản phẩm -->
                        <div class="max-h-60 overflow-y-auto divide-y divide-slate-100 pr-1 mb-6">
                            <div class="flex gap-3 py-3 first:pt-0">
                                <div class="w-12 h-12 bg-slate-100 rounded-md overflow-hidden flex-shrink-0 border border-slate-100">
                                    <img src="https://unsplash.com" alt="CPU" class="w-full h-full object-cover" />
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h4 class="text-sm font-medium text-slate-800 truncate">Bộ vi xử lý AMD Ryzen 5 5600X</h4>
                                    <div class="flex justify-between items-center mt-1">
                                        <span class="text-xs text-slate-500">SL: x1</span>
                                        <span class="text-sm font-medium text-slate-700">3,950,000đ</span>
                                    </div>
                                </div>
                            </div>

                            <div class="flex gap-3 py-3">
                                <div class="w-12 h-12 bg-slate-100 rounded-md overflow-hidden flex-shrink-0 border border-slate-100">
                                    <img src="https://unsplash.com" alt="RAM" class="w-full h-full object-cover" />
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h4 class="text-sm font-medium text-slate-800 truncate">RAM Corsair Vengeance LPX 16GB (2x8GB)</h4>
                                    <div class="flex justify-between items-center mt-1">
                                        <span class="text-xs text-slate-500">SL: x2</span>
                                        <span class="text-sm font-medium text-slate-700">1,900,000đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Tính tiền -->
                        <div class="space-y-3 mb-6 border-t border-slate-100 pt-4">
                            <div class="flex justify-between text-sm text-slate-600">
                                <span>Tạm tính</span>
                                <span>5,850,000đ</span>
                            </div>
                            <div class="flex justify-between text-sm text-slate-600">
                                <span>Phí vận chuyển</span>
                                <span class="text-emerald-600">Miễn phí</span>
                            </div>
                            <div class="border-t border-slate-200 pt-3 flex justify-between items-end">
                                <span class="text-base font-semibold text-slate-800">Tổng thanh toán</span>
                                <span class="text-xl font-bold text-red-600">5,850,000đ</span>
                            </div>
                        </div>

                        <!-- Nút đặt hàng -->
                        <button type="submit" class="w-full py-3 bg-primary-600 text-white text-center font-semibold rounded-lg hover:bg-primary-700 transition-colors flex items-center justify-center gap-2 cursor-pointer">
                            <i data-lucide="shield-check" class="w-5 h-5"></i>
                            Đặt hàng ngay
                        </button>

                        <p class="text-center text-xs text-slate-400 mt-4 flex items-center justify-center gap-1">
                            <i data-lucide="lock" class="w-3 h-3"></i>
                            Thông tin của bạn luôn được bảo mật
                        </p>
                    </div>
                </div>

            </div>
        </form>
    </div>

    <!-- Nạp Lucide Icons -->
    <script src="https://unpkg.com"></script>
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
