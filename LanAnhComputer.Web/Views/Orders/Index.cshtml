@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-primary-600">Trang chủ</a>

        <i data-lucide="chevron-right" class="w-4 h-4"></i>

        <span class="text-slate-800 font-medium">
            Đơn hàng của tôi
        </span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-slate-800">
            Đơn hàng của tôi
        </h1>

        <p class="text-slate-500 mt-2">
            Theo dõi trạng thái đơn hàng và lịch sử mua sắm
        </p>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-2xl border border-slate-200 p-2 mb-8 overflow-x-auto">
        <div class="flex gap-2 min-w-max">

            <button class="px-5 py-2.5 rounded-xl bg-primary-600 text-white font-medium">
                Tất cả
            </button>

            <button class="px-5 py-2.5 rounded-xl hover:bg-slate-100 text-slate-600 transition">
                Chờ xác nhận
            </button>

            <button class="px-5 py-2.5 rounded-xl hover:bg-slate-100 text-slate-600 transition">
                Đang giao
            </button>

            <button class="px-5 py-2.5 rounded-xl hover:bg-slate-100 text-slate-600 transition">
                Hoàn thành
            </button>

            <button class="px-5 py-2.5 rounded-xl hover:bg-slate-100 text-slate-600 transition">
                Đã huỷ
            </button>

        </div>
    </div>

    <!-- Order List -->
    <div class="space-y-6">

        <!-- ORDER 1 -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">

            <!-- Top -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 px-6 py-5 border-b border-slate-100 bg-slate-50">

                <div>
                    <div class="flex items-center gap-3 flex-wrap">

                        <span class="font-semibold text-slate-800">
                            #ORD-20260518-001
                        </span>

                        <span class="px-3 py-1 rounded-full bg-blue-100 text-primary-700 text-sm font-medium">
                            Đang giao hàng
                        </span>

                    </div>

                    <p class="text-sm text-slate-500 mt-1">
                        Đặt ngày: 18/05/2026
                    </p>
                </div>

                <div class="text-right">
                    <p class="text-sm text-slate-500">
                        Tổng thanh toán
                    </p>

                    <p class="text-2xl font-bold text-red-600">
                        35,990,000đ
                    </p>
                </div>

            </div>

            <!-- Products -->
            <div class="p-6 space-y-5">

                <!-- Product -->
                <div class="flex gap-4">

                    <img src="https://images.unsplash.com/photo-1593642702821-c8da6771f0c6?q=80&w=400"
                         class="w-24 h-24 rounded-xl object-cover border border-slate-200" />

                    <div class="flex-1 min-w-0">

                        <h3 class="font-semibold text-slate-800 line-clamp-2">
                            Laptop Gaming ASUS ROG Strix G16 RTX 4060
                        </h3>

                        <p class="text-sm text-slate-500 mt-1">
                            Phân loại: 16GB RAM / 1TB SSD
                        </p>

                        <div class="flex items-center justify-between mt-4">

                            <span class="text-sm text-slate-500">
                                Số lượng: x1
                            </span>

                            <span class="font-semibold text-slate-800">
                                32,990,000đ
                            </span>

                        </div>

                    </div>

                </div>

                <!-- Product -->
                <div class="flex gap-4">

                    <img src="https://images.unsplash.com/photo-1587202372775-e229f172b9d7?q=80&w=400"
                         class="w-24 h-24 rounded-xl object-cover border border-slate-200" />

                    <div class="flex-1 min-w-0">

                        <h3 class="font-semibold text-slate-800 line-clamp-2">
                            Chuột Logitech G Pro Wireless
                        </h3>

                        <p class="text-sm text-slate-500 mt-1">
                            Màu sắc: Đen
                        </p>

                        <div class="flex items-center justify-between mt-4">

                            <span class="text-sm text-slate-500">
                                Số lượng: x1
                            </span>

                            <span class="font-semibold text-slate-800">
                                3,000,000đ
                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Footer -->
            <div class="px-6 py-5 border-t border-slate-100 flex flex-col md:flex-row gap-3 justify-end">

                <button class="px-5 py-2.5 rounded-xl border border-slate-300 hover:bg-slate-100 transition">
                    Xem chi tiết
                </button>

                <button class="px-5 py-2.5 rounded-xl bg-primary-600 text-white hover:bg-primary-700 transition">
                    Theo dõi đơn hàng
                </button>

            </div>

        </div>

        <!-- ORDER 2 -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">

            <!-- Top -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 px-6 py-5 border-b border-slate-100 bg-slate-50">

                <div>
                    <div class="flex items-center gap-3 flex-wrap">

                        <span class="font-semibold text-slate-800">
                            #ORD-20260510-002
                        </span>

                        <span class="px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-sm font-medium">
                            Hoàn thành
                        </span>

                    </div>

                    <p class="text-sm text-slate-500 mt-1">
                        Đặt ngày: 10/05/2026
                    </p>
                </div>

                <div class="text-right">
                    <p class="text-sm text-slate-500">
                        Tổng thanh toán
                    </p>

                    <p class="text-2xl font-bold text-red-600">
                        5,850,000đ
                    </p>
                </div>

            </div>

            <!-- Products -->
            <div class="p-6">

                <div class="flex gap-4">

                    <img src="https://images.unsplash.com/photo-1541807084-5c52b6b3adef?q=80&w=400"
                         class="w-24 h-24 rounded-xl object-cover border border-slate-200" />

                    <div class="flex-1">

                        <h3 class="font-semibold text-slate-800">
                            Bộ vi xử lý AMD Ryzen 5 5600X
                        </h3>

                        <p class="text-sm text-slate-500 mt-1">
                            Số lượng: x1
                        </p>

                        <div class="mt-4 flex justify-between items-center">

                            <span class="text-emerald-600 text-sm font-medium flex items-center gap-1">
                                <i data-lucide="badge-check" class="w-4 h-4"></i>
                                Giao hàng thành công
                            </span>

                            <span class="font-semibold text-slate-800">
                                5,850,000đ
                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Footer -->
            <div class="px-6 py-5 border-t border-slate-100 flex flex-col md:flex-row gap-3 justify-end">

                <button class="px-5 py-2.5 rounded-xl border border-slate-300 hover:bg-slate-100 transition">
                    Xem chi tiết
                </button>

                <button class="px-5 py-2.5 rounded-xl bg-primary-600 text-white hover:bg-primary-700 transition">
                    Mua lại
                </button>

            </div>

        </div>

        <!-- ORDER 3 -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden opacity-90">

            <!-- Top -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 px-6 py-5 border-b border-slate-100 bg-slate-50">

                <div>
                    <div class="flex items-center gap-3 flex-wrap">

                        <span class="font-semibold text-slate-800">
                            #ORD-20260501-003
                        </span>

                        <span class="px-3 py-1 rounded-full bg-red-100 text-red-600 text-sm font-medium">
                            Đã huỷ
                        </span>

                    </div>

                    <p class="text-sm text-slate-500 mt-1">
                        Đặt ngày: 01/05/2026
                    </p>
                </div>

                <div class="text-right">
                    <p class="text-sm text-slate-500">
                        Tổng thanh toán
                    </p>

                    <p class="text-2xl font-bold text-slate-500">
                        12,500,000đ
                    </p>
                </div>

            </div>

            <!-- Product -->
            <div class="p-6">

                <div class="flex gap-4">

                    <img src="https://images.unsplash.com/photo-1517336714739-489689fd1ca8?q=80&w=400"
                         class="w-24 h-24 rounded-xl object-cover border border-slate-200" />

                    <div class="flex-1">

                        <h3 class="font-semibold text-slate-800">
                            Laptop Acer Nitro 5
                        </h3>

                        <p class="text-sm text-slate-500 mt-1">
                            Số lượng: x1
                        </p>

                        <div class="mt-4 flex justify-between items-center">

                            <span class="text-red-500 text-sm font-medium flex items-center gap-1">
                                <i data-lucide="x-circle" class="w-4 h-4"></i>
                                Đơn hàng đã bị huỷ
                            </span>

                            <span class="font-semibold text-slate-800">
                                12,500,000đ
                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Footer -->
            <div class="px-6 py-5 border-t border-slate-100 flex flex-col md:flex-row gap-3 justify-end">

                <button class="px-5 py-2.5 rounded-xl border border-slate-300 hover:bg-slate-100 transition">
                    Xem chi tiết
                </button>

                <button class="px-5 py-2.5 rounded-xl bg-primary-600 text-white hover:bg-primary-700 transition">
                    Mua lại
                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        lucide.createIcons();
    </script>
}