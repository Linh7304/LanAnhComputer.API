                <div class="w-16 h-16 bg-emerald-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                    <i data-lucide="cpu" class="w-8 h-8 text-white"></i>
                </div>
                <h3 class="font-semibold text-slate-800">Linh kiện</h3>
                <p class="text-sm text-slate-500">500+ sản phẩm</p>
            </a>
            
            <!-- Gaming -->
