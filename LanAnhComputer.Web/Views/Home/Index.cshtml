@using LanAnhComputer.Web.ViewModels
@{
    ViewData["Title"] = "Trang chủ";
}


<!-- Hero Slider -->
<section class="relative">
    <div id="hero-slider" class="relative overflow-hidden">
        <div id="slider-track" class="flex transition-transform duration-500 ease-out">
            <!-- Slide 1 -->
            <div class="w-full flex-shrink-0 bg-gradient-to-r from-primary-600 to-primary-800 text-white">
                <div class="container mx-auto px-4 py-16 md:py-24">
                    <div class="max-w-2xl">
                        <span class="inline-block px-4 py-1 bg-white/20 rounded-full text-sm font-medium mb-4">
                            Khuyến mãi tháng 5
                        </span>
                        <h2 class="text-3xl md:text-5xl font-bold mb-4 text-balance">
                            Giảm đến 30% Laptop Gaming
                        </h2>
                        <p class="text-lg text-primary-100 mb-6">
                            Sở hữu ngay laptop gaming hiệu năng cao với giá ưu đãi chưa từng có. Trả góp 0% lãi suất.
                        </p>
                        <div class="flex gap-4">
                            <a href="/san-pham?category=gaming" class="px-6 py-3 bg-white text-primary-600 font-semibold rounded-lg hover:bg-primary-50 transition-colors">
                                Mua ngay
                            </a>
                            <a href="#" class="px-6 py-3 border border-white/50 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Slide 2 -->
            <div class="w-full flex-shrink-0 bg-gradient-to-r from-slate-800 to-slate-900 text-white">
                <div class="container mx-auto px-4 py-16 md:py-24">
                    <div class="max-w-2xl">
                        <span class="inline-block px-4 py-1 bg-orange-500 rounded-full text-sm font-medium mb-4">
                            Mới ra mắt
                        </span>
                        <h2 class="text-3xl md:text-5xl font-bold mb-4 text-balance">
                            PC Build theo yêu cầu
                        </h2>
                        <p class="text-lg text-slate-300 mb-6">
                            Đội ngũ kỹ thuật chuyên nghiệp sẽ tư vấn và lắp ráp PC theo đúng nhu cầu của bạn.
                        </p>
                        <div class="flex gap-4">
                            <a href="/san-pham?category=pc" class="px-6 py-3 bg-orange-500 text-white font-semibold rounded-lg hover:bg-orange-600 transition-colors">
                                Tư vấn ngay
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Slide 3 -->
            <div class="w-full flex-shrink-0 bg-gradient-to-r from-emerald-600 to-teal-700 text-white">
                <div class="container mx-auto px-4 py-16 md:py-24">
                    <div class="max-w-2xl">
                        <span class="inline-block px-4 py-1 bg-white/20 rounded-full text-sm font-medium mb-4">
                            Ưu đãi đặc biệt
                        </span>
                        <h2 class="text-3xl md:text-5xl font-bold mb-4 text-balance">
                            Linh kiện chính hãng
                        </h2>
                        <p class="text-lg text-emerald-100 mb-6">
                            Bảo hành 36 tháng. Đổi mới trong 30 ngày nếu có lỗi từ nhà sản xuất.
                        </p>
                        <div class="flex gap-4">
                            <a href="/san-pham?category=linh-kien" class="px-6 py-3 bg-white text-emerald-600 font-semibold rounded-lg hover:bg-emerald-50 transition-colors">
                                Khám phá
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Slider Controls -->
        <button onclick="prevSlide()" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center text-white transition-colors">
            <i data-lucide="chevron-left" class="w-6 h-6"></i>
        </button>
        <button onclick="nextSlide()" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center text-white transition-colors">
            <i data-lucide="chevron-right" class="w-6 h-6"></i>
        </button>
        
        <!-- Dots -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
            <button onclick="goToSlide(0)" class="slider-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-colors" data-index="0"></button>
            <button onclick="goToSlide(1)" class="slider-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-colors" data-index="1"></button>
            <button onclick="goToSlide(2)" class="slider-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-colors" data-index="2"></button>
        </div>
    </div>
</section>

<!-- Categories Section -->
