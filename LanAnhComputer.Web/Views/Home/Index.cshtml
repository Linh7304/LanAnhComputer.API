                </div>
                <div>
                    <h4 class="font-semibold text-slate-800">Đổi trả dễ dàng</h4>
                    <p class="text-sm text-slate-500">Trong 30 ngày</p>
                </div>
            </div>
            
            <div class="flex items-center gap-4 p-4 bg-white rounded-xl">
                <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
                    <i data-lucide="headset" class="w-6 h-6 text-purple-600"></i>
                </div>
                <div>
                    <h4 class="font-semibold text-slate-800">Hỗ trợ 24/7</h4>
                    <p class="text-sm text-slate-500">Hotline 1900 1234</p>
                </div>
