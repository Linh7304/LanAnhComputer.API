                <div class="w-16 h-16 bg-red-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                    <i data-lucide="gamepad-2" class="w-8 h-8 text-white"></i>
                </div>
                <h3 class="font-semibold text-slate-800">Gaming Gear</h3>
                <p class="text-sm text-slate-500">200+ sản phẩm</p>
            </a>
            
            <!-- Phu kien -->
            <a href="/san-pham?category=phu-kien" class="group p-6 bg-gradient-to-br from-amber-50 to-amber-100 rounded-2xl hover:shadow-lg transition-all hover:-translate-y-1">
                <div class="w-16 h-16 bg-amber-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
