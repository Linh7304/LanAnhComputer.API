<!-- Featured Products -->
<section class="py-12 bg-white">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-slate-800">Sản phẩm nổi bật</h2>
            <div class="flex gap-2">
                <button onclick="setProductTab('hot')" class="product-tab px-4 py-2 rounded-lg font-medium transition-colors bg-primary-600 text-white" data-tab="hot">
                    Bán chạy
                </button>
                <button onclick="setProductTab('new')" class="product-tab px-4 py-2 rounded-lg font-medium transition-colors bg-slate-100 text-slate-600 hover:bg-slate-200" data-tab="new">
                    Mới nhất
                </button>
                <button onclick="setProductTab('sale')" class="product-tab px-4 py-2 rounded-lg font-medium transition-colors bg-slate-100 text-slate-600 hover:bg-slate-200" data-tab="sale">
                    Giảm giá
                </button>
            </div>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
            @foreach (var product in Model)
            {
                @await Html.PartialAsync("_ProductCard", (LanAnhComputer.Web.ViewModels.ProductViewModel)product)
            }

           
           
          
        </div>
        
        <div class="text-center mt-8">
            <a href="/san-pham" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary-600 text-primary-600 font-semibold rounded-lg hover:bg-primary-600 hover:text-white transition-colors">
                Xem tất cả sản phẩm
                <i data-lucide="arrow-right" class="w-5 h-5"></i>
            </a>
        </div>
    </div>
</section>

<!-- Features -->
