                    <i data-lucide="laptop" class="w-8 h-8 text-white"></i>
                </div>
                <h3 class="font-semibold text-slate-800">Laptop</h3>
                <p class="text-sm text-slate-500">150+ sản phẩm</p>
            </a>
            
            <!-- PC -->
