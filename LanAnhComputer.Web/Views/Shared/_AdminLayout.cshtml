<!DOCTYPE html>
@{
    var fullName = Context.Session.GetString("FullName") ?? "Admin";
}
<html lang="vi" class="bg-slate-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | Lan Anh Computer</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: {
        50: '#eff6ff',
        100: '#dbeafe',
        200: '#bfdbfe',
        300: '#93c5fd',
        400: '#60a5fa',
        500: '#3b82f6',
        600: '#2563eb',
        700: '#1d4ed8',
        800: '#1e40af',
        900: '#1e3a8a',
        },
        sidebar: {
        DEFAULT: '#1e293b',
        foreground: '#f1f5f9',
        accent: '#334155',
        }
        }
        }
        }
        }
    </script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <style>
        body {
        font-family: 'Inter', sans-serif;
        }
    </style>
    
    @RenderSection("Styles", required: false)
</head>
<body class="min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-sidebar text-sidebar-foreground flex-shrink-0 fixed h-full overflow-y-auto">
        <!-- Logo -->
        <div class="p-6 border-b border-slate-700">
            <a href="/admin" class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center">
                    <i data-lucide="monitor" class="w-6 h-6 text-white"></i>
                </div>
                <div>
                    <h1 class="font-bold text-lg">Lan Anh</h1>
                    <p class="text-xs text-slate-400">Admin Panel</p>
                </div>
            </a>
        </div>
        
        <!-- Navigation -->
        <nav class="p-4">
            <ul class="space-y-1">
                <li>
                    <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                        <span>Tổng quan</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/don-hang" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Orders" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                        <span>Đơn hàng</span>
                        <span class="ml-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">12</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/san-pham" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Products" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="package" class="w-5 h-5"></i>
                        <span>Sản phẩm</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/danh-muc" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Categories" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="tags" class="w-5 h-5"></i>
                        <span>Danh mục</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/kho-hang" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Inventory" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="warehouse" class="w-5 h-5"></i>
                        <span>Kho hàng</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Users" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="users" class="w-5 h-5"></i>
                        <span>Users</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/chatbot" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Chatbot" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="message-square" class="w-5 h-5"></i>
                        <span>Quản lý Chatbot</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/bao-cao" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Reports" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="bar-chart-3" class="w-5 h-5"></i>
                        <span>Báo cáo</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/cai-dat" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-sidebar-accent transition-colors @(ViewData["ActivePage"]?.ToString() == "Settings" ? "bg-sidebar-accent text-white" : "text-slate-300")">
                        <i data-lucide="settings" class="w-5 h-5"></i>
                        <span>Cài đặt</span>
                    </a>
                </li>
            </ul>
        </nav>
        
        <!-- User -->
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-slate-700">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center text-white font-semibold">
                    @fullName.Substring(0, 1).ToUpper()
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-medium text-sm truncate">@fullName</p>
                    <p class="text-xs text-slate-400 truncate">Admin</p>
                </div>
                <a href="/" class="p-2 hover:bg-sidebar-accent rounded-lg transition-colors" title="Về trang chủ">
                    <i data-lucide="external-link" class="w-4 h-4 text-slate-400"></i>
                </a>
            </div>
        </div>
    </aside>
    
    <!-- Main Content -->
    <div class="flex-1 ml-64">
        <!-- Header -->
        <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
            <div class="flex items-center justify-between px-6 py-4">
                <div>
                    <h1 class="text-xl font-semibold text-slate-800">@ViewData["Title"]</h1>
                </div>
                <div class="flex items-center gap-4">
                    <!-- Search -->
                    <div class="relative">
                        <input type="text" placeholder="Tìm kiếm..." class="w-64 pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                        <i data-lucide="search" class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2"></i>
                    </div>
                    
                    <!-- Notifications -->
                    <button class="relative p-2 hover:bg-slate-100 rounded-lg">
                        <i data-lucide="bell" class="w-5 h-5 text-slate-600"></i>
                        <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                    </button>
                    
                    <!-- Profile -->
                    <button class="flex items-center gap-2 hover:bg-slate-100 rounded-lg p-2">
                        <div class="w-8 h-8 bg-primary-600 rounded-full flex items-center justify-center text-white text-sm font-semibold">
                            @fullName.Substring(0, 1).ToUpper()
                        </div>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-slate-600"></i>
                    </button>
                </div>
            </div>
        </header>
        
        <!-- Page Content -->
        <main class="p-6">
            @RenderBody()
        </main>
    </div>
    
    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
