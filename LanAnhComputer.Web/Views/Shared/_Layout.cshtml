                </div>
            </div>
            
            <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-400 text-sm">
                <p>&copy; 2024 Lan Anh Computer. Tất cả quyền được bảo lưu.</p>
            </div>
        </div>
    </footer>

    <!-- Login/Register Modal -->
    <!-- Auth Modal -->
    @await Html.PartialAsync("_AuthModal")
   
    
    <!-- Chatbot Widget -->
    @await Html.PartialAsync("_ChatbotWidget")
    
    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
    <!-- Auth Script -->
    <script>
        let currentMode = 'login';

        // Mở modal
        function openAuthModal(mode = 'login') {
        currentMode = mode;

        const modal = document.getElementById('authModal');
        const title = document.getElementById('authModalTitle');
        const registerFields = document.getElementById('registerFields');
        const submitBtn = document.getElementById('authSubmitBtn');
        const switchArea = document.getElementById('switchArea');

        modal.classList.remove('hidden');

        if (mode === 'login') {
        title.textContent = 'Đăng nhập';
        submitBtn.textContent = 'Đăng nhập';

        registerFields.classList.add('hidden');

        switchArea.innerHTML = `
        Chưa có tài khoản?
        <button type="button"
        onclick="openAuthModal('register')"
        class="text-primary-600 font-bold hover:underline">
        Đăng ký ngay
        </button>
        `;
        } else {
        title.textContent = 'Đăng ký tài khoản';
        submitBtn.textContent = 'Tạo tài khoản';

        registerFields.classList.remove('hidden');

        switchArea.innerHTML = `
        Đã có tài khoản?
        <button type="button"
        onclick="openAuthModal('login')"
        class="text-primary-600 font-bold hover:underline">
        Đăng nhập
        </button>
        `;
        }

        lucide.createIcons();
        }

        // Đóng modal
        function closeAuthModal() {
        document.getElementById('authModal').classList.add('hidden');
        }

        // Submit form
        async function handleAuthSubmit(event) {
        event.preventDefault();

        const email = document.getElementById('authEmail').value;
        const password = document.getElementById('authPassword').value;

        const payload = {
        email,
        password
        };

        // Nếu đăng ký thì thêm thông tin
        if (currentMode === 'register') {
        payload.fullName = document.getElementById('regFullName').value;
        payload.phone = document.getElementById('regPhone').value;
        }

        // URL API
        const url =
        currentMode === 'login'
        ? 'https://localhost:7132/api/Auth/login'
        : 'https://localhost:7132/api/Auth/register';

        try {
        const response = await fetch(url, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (response.ok) {

        // Lưu token
        if (data.token) {
        localStorage.setItem('token', data.token);
        }

        if (data.role) {
        localStorage.setItem('userRole', data.role);
        }
        updateAuthButton();
        alert(
        currentMode === 'login'
        ? 'Đăng nhập thành công!'
        : 'Đăng ký thành công!'
        );

        // Redirect
        if (data.role === 'Admin') {
        window.location.href = '/dashboard';
        } else {
        window.location.href = '/';
        }

        } else {
        alert(data.message || 'Có lỗi xảy ra!');
        }

        } catch (error) {
        console.error(error);
        alert('Không thể kết nối tới server API');
        }
        }
        // Kiểm tra trạng thái đăng nhập
        function updateAuthButton() {

        const token = localStorage.getItem('token');

        const buttonText = document.getElementById('authButtonText');

        if (token) {
        buttonText.textContent = 'Đăng xuất';
        } else {
        buttonText.textContent = 'Đăng nhập';
        }
        }
        function handleAuthButton() {

        const token = localStorage.getItem('token');

        // Nếu đã đăng nhập -> logout
        if (token) {

        localStorage.removeItem('token');
        localStorage.removeItem('userRole');

        alert('Đã đăng xuất!');

        updateAuthButton();

        window.location.href = '/';

        } else {

        // Nếu chưa đăng nhập -> mở modal login
        openAuthModal('login');
        }
        }
            function handleCartClick() {

            const token = localStorage.getItem('token');

            // Chưa login
            if (!token) {

            openAuthModal('login');
            return;
            }

            // Đã login
            window.location.href = '/Cart';
            }

        // Khởi tạo trạng thái button khi tải trang
        document.addEventListener('DOMContentLoaded', function() {
            updateAuthButton();
        });

    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
