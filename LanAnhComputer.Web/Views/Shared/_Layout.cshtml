                            <i data-lucide="instagram" class="w-5 h-5"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Quick Links -->
                <div>
                    <h4 class="font-semibold text-lg mb-4">Về chúng tôi</h4>
                    <ul class="space-y-2 text-slate-400">
                        <li><a href="#" class="hover:text-white transition-colors">Giới thiệu</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Hệ thống cửa hàng</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Tuyển dụng</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Liên hệ</a></li>
                    </ul>
                </div>
                
                <!-- Support -->
                <div>
                    <h4 class="font-semibold text-lg mb-4">Hỗ trợ khách hàng</h4>
                    <ul class="space-y-2 text-slate-400">
