                        <i data-lucide="user" class="w-5 h-5"></i>

                        <span id="authButtonText" class="hidden sm:inline">
                            Đăng nhập
                        </span>
                    </button>

                </div>
            </div>
        </div>
        
        <!-- Navigation -->
        <nav class="bg-slate-50 border-t border-slate-200">
            <div class="container mx-auto px-4">
                <ul class="flex items-center gap-1 overflow-x-auto py-2">
                    <li>
                        <a href="/san-pham?category=laptop" class="flex items-center gap-2 px-4 py-2 text-slate-700 hover:bg-white hover:text-primary-600 rounded-lg transition-colors whitespace-nowrap">
                            <i data-lucide="laptop" class="w-5 h-5"></i>
                            Laptop
                        </a>
                    </li>
                    <li>
                        <a href="/san-pham?category=pc" class="flex items-center gap-2 px-4 py-2 text-slate-700 hover:bg-white hover:text-primary-600 rounded-lg transition-colors whitespace-nowrap">
                            <i data-lucide="monitor" class="w-5 h-5"></i>
                            PC - Máy tính bàn
                        </a>
                    </li>
                    <li>
                        <a href="/san-pham?category=linh-kien" class="flex items-center gap-2 px-4 py-2 text-slate-700 hover:bg-white hover:text-primary-600 rounded-lg transition-colors whitespace-nowrap">
                            <i data-lucide="cpu" class="w-5 h-5"></i>
                            Linh kiện
                        </a>
                    </li>
                    <li>
                        <a href="/san-pham?category=gaming" class="flex items-center gap-2 px-4 py-2 text-slate-700 hover:bg-white hover:text-primary-600 rounded-lg transition-colors whitespace-nowrap">
                            <i data-lucide="gamepad-2" class="w-5 h-5"></i>
                            Gaming Gear
                        </a>
                    </li>
                    <li>
                        <a href="/san-pham?category=phu-kien" class="flex items-center gap-2 px-4 py-2 text-slate-700 hover:bg-white hover:text-primary-600 rounded-lg transition-colors whitespace-nowrap">
                            <i data-lucide="headphones" class="w-5 h-5"></i>
                            Phụ kiện
                        </a>
                    </li>
                    <li>
                        <a href="/khuyen-mai" class="flex items-center gap-2 px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors whitespace-nowrap font-medium">
                            <i data-lucide="zap" class="w-5 h-5"></i>
                            Khuyến mãi HOT
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>
    
    <!-- Main Content -->
    <main class="flex-1">
        @RenderBody()
    </main>
    
    <!-- Footer -->
    <footer class="bg-slate-900 text-white mt-12">
        <div class="container mx-auto px-4 py-12">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Company Info -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center">
                            <i data-lucide="monitor" class="w-6 h-6 text-white"></i>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold">Lan Anh</h3>
                            <p class="text-xs text-slate-400">Computer</p>
                        </div>
                    </div>
                    <p class="text-slate-400 text-sm mb-4">
                        Cửa hàng máy tính uy tín hàng đầu Việt Nam. Chuyên cung cấp Laptop, PC, Linh kiện chính hãng với giá tốt nhất.
                    </p>
                    <div class="flex gap-3">
