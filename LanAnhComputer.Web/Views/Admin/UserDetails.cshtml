@model LanAnhComputer.Dtos.UserDto

@{
    ViewData["Title"] = "Chi tiet user";
    ViewData["ActivePage"] = "Users";
    Layout = "_AdminLayout";
}

<div class="bg-white rounded-xl border border-slate-200 p-6 max-w-3xl">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold text-slate-800">@Model.FullName</h2>
            <p class="text-sm text-slate-500">@Model.Email</p>
        </div>
        <a href="/admin/users" class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100">Quay lai</a>
    </div>

    <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <dt class="text-sm text-slate-500">UserId</dt>
            <dd class="font-medium text-slate-800">@Model.UserId</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Phone</dt>
            <dd class="font-medium text-slate-800">@Model.Phone</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Role</dt>
            <dd class="font-medium text-slate-800">@Model.Role</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">IsActive</dt>
            <dd class="font-medium text-slate-800">@Model.IsActive</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">CreatedAt</dt>
            <dd class="font-medium text-slate-800">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Address</dt>
            <dd class="font-medium text-slate-800">@Model.AddressLine @Model.Ward @Model.District @Model.City</dd>
        </div>
    </dl>
</div>
