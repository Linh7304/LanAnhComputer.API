@model LanAnhComputer.Web.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Tong quan";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "_AdminLayout";
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center">
                <i data-lucide="package-x" class="w-6 h-6 text-red-600"></i>
            </div>
        </div>
        <p class="text-sm text-slate-500 mb-1">San pham het hang</p>
        <p class="text-2xl font-bold text-slate-800">@Model.OutOfStockCount</p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center">
                <i data-lucide="triangle-alert" class="w-6 h-6 text-yellow-600"></i>
            </div>
        </div>
        <p class="text-sm text-slate-500 mb-1">San pham sap het</p>
        <p class="text-2xl font-bold text-slate-800">@Model.LowStockCount</p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                <i data-lucide="trending-up" class="w-6 h-6 text-emerald-600"></i>
            </div>
        </div>
        <p class="text-sm text-slate-500 mb-1">Top ban chay</p>
        <p class="text-2xl font-bold text-slate-800">@Model.TopSellingProducts.Count</p>
    </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="flex items-center justify-between p-6 border-b border-slate-200">
        <h2 class="text-lg font-semibold text-slate-800">Top san pham ban chay</h2>
        <a href="/admin/kho-hang" class="text-primary-600 hover:text-primary-700 text-sm font-medium">Quan ly kho</a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">San pham</th>
                    <th class="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">So luong ban</th>
                    <th class="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">Doanh thu</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model.TopSellingProducts.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center text-slate-500">Chua co du lieu ban hang.</td>
                    </tr>
                }
                @foreach (var product in Model.TopSellingProducts)
                {
                    <tr class="hover:bg-slate-50">
                        <td class="px-6 py-4 font-medium text-slate-800">@product.ProductName</td>
                        <td class="px-6 py-4 text-right text-slate-700">@product.SoldQuantity</td>
                        <td class="px-6 py-4 text-right font-semibold text-slate-800">@product.Revenue.ToString("N0")đ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
