@model List<LanAnhComputer.Dtos.InventoryItemDto>

@{
    ViewData["Title"] = "Quản lý kho hàng";
    ViewData["ActivePage"] = "Inventory";
    Layout = "_AdminLayout";
    var status = ViewBag.Status as string;
}

@if (TempData["Success"] != null)
{
    <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@TempData["Error"]</div>
}

<div class="flex items-center justify-between gap-4 mb-6">
    <div class="flex items-center gap-2">
        <a href="/admin/kho-hang" class="px-4 py-2 rounded-lg border @(string.IsNullOrEmpty(status) ? "bg-primary-600 text-white border-primary-600" : "border-slate-300 hover:bg-slate-100")">Tat ca</a>
        <a href="/admin/kho-hang?status=low" class="px-4 py-2 rounded-lg border @(status == "low" ? "bg-yellow-500 text-white border-yellow-500" : "border-slate-300 hover:bg-slate-100")">Sap het</a>
        <a href="/admin/kho-hang?status=out" class="px-4 py-2 rounded-lg border @(status == "out" ? "bg-red-600 text-white border-red-600" : "border-slate-300 hover:bg-slate-100")">Het hang</a>
    </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Sản phẩm</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Giá nhập</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Giá bán</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Tồn kho</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Ngưỡng cảnh báo</th>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Trạng thái</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="px-6 py-8 text-center text-slate-500">Chưa có dữ liệu kho hàng.</td>
                    </tr>
                }
                @foreach (var item in Model ?? new List<LanAnhComputer.Dtos.InventoryItemDto>())
                {
                    var badgeClass = item.StockStatus switch
                    {
                        "OutOfStock" => "bg-red-100 text-red-700",
                        "LowStock" => "bg-yellow-100 text-yellow-700",
                        _ => "bg-emerald-100 text-emerald-700"
                    };
                    var badgeText = item.StockStatus switch
                    {
                        "OutOfStock" => "Hết hàng",
                        "LowStock" => "Sắp hết",
                        _ => "Còn hàng"
                    };

                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-4">
                            <p class="font-medium text-slate-800">@item.ProductName</p>
                            <p class="text-xs text-slate-500">@item.ProductCode · @item.Brand</p>
                        </td>
                        <td class="px-4 py-4 text-sm text-right">@item.ImportPrice.ToString("N0")đ</td>
                        <td class="px-4 py-4 text-sm text-right">@item.SalePrice.ToString("N0")đ</td>
                        <td class="px-4 py-4 text-sm font-semibold text-right">@item.StockQuantity</td>
                        <td class="px-4 py-4 text-sm text-right">@item.LowStockThreshold</td>
                        <td class="px-4 py-4">
                            <span class="px-2.5 py-1 text-xs font-medium rounded-full @badgeClass">@badgeText</span>
                        </td>
                        <td class="px-4 py-4">
                            <div class="flex justify-end gap-2">
                                <button type="button"
                                        onclick="openUpdateStock(this)"
                                        class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg hover:bg-slate-100"
                                        data-product-id="@item.ProductId"
                                        data-stock="@item.StockQuantity"
                                        data-threshold="@item.LowStockThreshold"
                                        data-import-price="@item.ImportPrice"
                                        data-sale-price="@item.SalePrice">
                                    Sửa tồn
                                </button>
                                <button type="button"
                                        onclick="openImportStock(this)"
                                        class="px-3 py-1.5 text-sm border border-primary-200 text-primary-700 rounded-lg hover:bg-primary-50"
                                        data-product-id="@item.ProductId"
                                        data-import-price="@item.ImportPrice">
                                    Nhập hàng
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="stockModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" onclick="closeStockModal()"></div>
    <div class="absolute top-1/2 left-1/2 w-full max-w-lg -translate-x-1/2 -translate-y-1/2 rounded-xl bg-white shadow-xl">
        <div class="flex items-center justify-between border-b border-slate-200 p-5">
            <h2 id="stockModalTitle" class="text-lg font-semibold">Cập nhật kho</h2>
            <button type="button" onclick="closeStockModal()" class="p-2 hover:bg-slate-100 rounded-lg">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <form id="stockForm" method="post" class="p-5 space-y-4">
            @Html.AntiForgeryToken()
            <div id="updateFields" class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Tồn kho</label>
                    <input id="StockQuantity" name="StockQuantity" type="number" min="0" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Ngưỡng cảnh báo</label>
                    <input id="LowStockThreshold" name="LowStockThreshold" type="number" min="0" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Giá nhập</label>
                    <input id="ImportPrice" name="ImportPrice" type="number" min="0" step="1000" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Giá bán</label>
                    <input id="SalePrice" name="SalePrice" type="number" min="0" step="1000" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>
            </div>
            <div id="importFields" class="grid grid-cols-2 gap-4 hidden">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Số lượng nhập</label>
                    <input id="Quantity" name="Quantity" type="number" min="1" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Giá nhập mới</label>
                    <input id="ImportPriceNew" name="ImportPrice" type="number" min="0" step="1000" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>
            </div>
            <div class="flex justify-end gap-3 border-t border-slate-200 pt-4">
                <button type="button" onclick="closeStockModal()" class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100">Huy</button>
                <button class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Luu</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openUpdateStock(button) {
            const data = button.dataset;
            document.getElementById('stockModalTitle').textContent = 'Sua so luong ton';
            document.getElementById('stockForm').action = `/admin/kho-hang/${data.productId}/cap-nhat`;
            document.getElementById('updateFields').classList.remove('hidden');
            document.getElementById('importFields').classList.add('hidden');
            document.getElementById('StockQuantity').value = data.stock;
            document.getElementById('LowStockThreshold').value = data.threshold;
            document.getElementById('ImportPrice').value = data.importPrice;
            document.getElementById('SalePrice').value = data.salePrice;
            document.getElementById('stockModal').classList.remove('hidden');
            lucide.createIcons();
        }

        function openImportStock(button) {
            const data = button.dataset;
            document.getElementById('stockModalTitle').textContent = 'Nhap them hang';
            document.getElementById('stockForm').action = `/admin/kho-hang/${data.productId}/nhap`;
            document.getElementById('updateFields').classList.add('hidden');
            document.getElementById('importFields').classList.remove('hidden');
            document.getElementById('Quantity').value = 1;
            document.getElementById('ImportPriceNew').value = data.importPrice;
            document.getElementById('stockModal').classList.remove('hidden');
            lucide.createIcons();
        }

        function closeStockModal() {
            document.getElementById('stockModal').classList.add('hidden');
        }
    </script>
}
