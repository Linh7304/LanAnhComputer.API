@model LanAnhComputer.Web.ViewModels.PagedResultViewModel<LanAnhComputer.Web.ViewModels.ProductViewModel>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    ViewData["ActivePage"] = "Products";
    Layout = "_AdminLayout";
    var products = Model?.Items ?? new List<LanAnhComputer.Web.ViewModels.ProductViewModel>();
    var search = ViewBag.Search as string;
}

@if (TempData["Success"] != null)
{
    <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@TempData["Error"]</div>
}

<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <form method="get" action="/admin/san-pham" class="flex items-center gap-3">
        <div class="relative">
            <input name="search" value="@search" type="text" placeholder="Tìm kiếm sản phẩm..."
                   class="w-80 pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <i data-lucide="search" class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2"></i>
        </div>
        <button class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100">Tìm</button>
    </form>

    <button onclick="openAddModal()" class="flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
        <i data-lucide="plus" class="w-4 h-4"></i>
        Thêm sản phẩm
    </button>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Sản phẩm</th>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Mã SP</th>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Loại</th>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Thương hiệu</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Giá bán</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Tồn kho</th>
                    <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Trạng thái</th>
                    <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (!products.Any())
                {
                    <tr>
                        <td colspan="8" class="px-4 py-8 text-center text-slate-500">Chưa có sản phẩm.</td>
                    </tr>
                }
                @foreach (var product in products)
                {
                    var stockClass = product.StockQuantity == 0 ? "text-red-600 font-semibold" : product.StockQuantity < 10 ? "text-orange-600 font-semibold" : "text-slate-700";
                    var statusClass = product.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-600";
                    var statusText = product.IsActive ? "Đang bán" : "Ngừng bán";

                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-slate-100 rounded-lg overflow-hidden flex-shrink-0">
                                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.ProductName" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center text-xs text-slate-400">SP</div>
                                    }
                                </div>
                                <div>
                                    <p class="font-medium text-slate-800">@product.ProductName</p>
                                    <p class="text-xs text-slate-500">ID: @product.ProductId</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-4 text-sm text-slate-600">@product.ProductCode</td>
                        <td class="px-4 py-4 text-sm text-slate-600">@product.ProductType</td>
                        <td class="px-4 py-4 text-sm text-slate-600">@product.Brand</td>
                        <td class="px-4 py-4 text-sm font-medium text-slate-800 text-right">@product.SalePrice.ToString("N0")đ</td>
                        <td class="px-4 py-4 text-sm text-right @stockClass">@product.StockQuantity</td>
                        <td class="px-4 py-4">
                            <span class="px-2.5 py-1 text-xs font-medium rounded-full @statusClass">@statusText</span>
                        </td>
                        <td class="px-4 py-4 text-right">
                            <div class="flex items-center justify-end gap-1">
                                <a href="/admin/san-pham/@product.ProductId/chi-tiet" class="p-2 hover:bg-slate-100 rounded-lg" title="Quan ly anh va thong so">
                                    <i data-lucide="image" class="w-4 h-4 text-slate-500"></i>
                                </a>
                                <button type="button"
                                        onclick="openEditModal(this)"
                                        class="p-2 hover:bg-slate-100 rounded-lg"
                                        title="Chỉnh sửa"
                                        data-product-id="@product.ProductId"
                                        data-category-id="@product.CategoryId"
                                        data-product-code="@product.ProductCode"
                                        data-product-name="@product.ProductName"
                                        data-product-type="@product.ProductType"
                                        data-brand="@product.Brand"
                                        data-model="@product.Model"
                                        data-short-description="@product.ShortDescription"
                                        data-description="@product.Description"
                                        data-thumbnail-url="@product.ThumbnailUrl"
                                        data-specifications="@product.Specifications"
                                        data-warranty-months="@product.WarrantyMonths"
                                        data-cost-price="@product.CostPrice"
                                        data-sale-price="@product.SalePrice"
                                        data-stock-quantity="@product.StockQuantity"
                                        data-reorder-level="@product.ReorderLevel"
                                        data-image-url="@product.ImageUrl"
                                        data-is-active="@product.IsActive.ToString().ToLowerInvariant()">
                                    <i data-lucide="pencil" class="w-4 h-4 text-slate-500"></i>
                                </button>
                                <form method="post" action="/admin/san-pham/xoa/@product.ProductId" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?')" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button class="p-2 hover:bg-red-100 rounded-lg" title="Xóa">
                                        <i data-lucide="trash-2" class="w-4 h-4 text-red-500"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-between px-6 py-4 border-t border-slate-200">
        <p class="text-sm text-slate-500">Tổng cộng @(Model?.TotalItems ?? products.Count) sản phẩm</p>
        <p class="text-sm text-slate-500">Trang @(Model?.PageNumber ?? 1) / @(Model?.TotalPages ?? 1)</p>
    </div>
</div>

<div id="productModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" onclick="closeModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl bg-white rounded-2xl shadow-xl max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between p-6 border-b border-slate-200">
            <h2 id="modalTitle" class="text-xl font-semibold text-slate-800">Thêm sản phẩm mới</h2>
            <button type="button" onclick="closeModal()" class="p-2 hover:bg-slate-100 rounded-lg">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>

        <form id="productForm" method="post" action="/admin/san-pham/them" enctype="multipart/form-data" class="p-6 space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" id="ProductId" name="ProductId" />
            <input type="hidden" id="ImageUrl" name="ImageUrl" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Mã sản phẩm *</label>
                    <input id="ProductCode" name="ProductCode" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Tên sản phẩm *</label>
                    <input id="ProductName" name="ProductName" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">CategoryId *</label>
                    <input id="CategoryId" name="CategoryId" type="number" min="1" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Loại sản phẩm *</label>
                    <input id="ProductType" name="ProductType" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Thương hiệu</label>
                    <input id="Brand" name="Brand" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Model</label>
                    <input id="Model" name="Model" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Giá nhập</label>
                    <input id="CostPrice" name="CostPrice" type="number" step="1000" min="0" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Giá bán *</label>
                    <input id="SalePrice" name="SalePrice" type="number" step="1000" min="0" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Tồn kho *</label>
                    <input id="StockQuantity" name="StockQuantity" type="number" min="0" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Mức cảnh báo</label>
                    <input id="ReorderLevel" name="ReorderLevel" type="number" min="0" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Bảo hành (tháng)</label>
                    <input id="WarrantyMonths" name="WarrantyMonths" type="number" min="0" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Hình ảnh</label>
                    <input id="Image" name="Image" type="file" accept="image/*" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Thumbnail URL</label>
                    <input id="ThumbnailUrl" name="ThumbnailUrl" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Mo ta ngan</label>
                    <textarea id="ShortDescription" name="ShortDescription" rows="2" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Mo ta chi tiet</label>
                    <textarea id="Description" name="Description" rows="4" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Thông số</label>
                    <textarea id="Specifications" name="Specifications" rows="3" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
                </div>
                <label class="flex items-center gap-2">
                    <input id="IsActive" name="IsActive" type="checkbox" value="true" checked class="w-4 h-4 rounded border-slate-300" />
                    <input name="IsActive" type="hidden" value="false" />
                    <span class="text-sm text-slate-700">Đang bán</span>
                </label>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-200">
                <button type="button" onclick="closeModal()" class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">Hủy</button>
                <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">Lưu sản phẩm</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() {
            const form = document.getElementById('productForm');
            form.reset();
            form.action = '/admin/san-pham/them';
            document.getElementById('ProductId').value = '';
            document.getElementById('ImageUrl').value = '';
            document.getElementById('IsActive').checked = true;
            document.getElementById('modalTitle').textContent = 'Thêm sản phẩm mới';
            document.getElementById('productModal').classList.remove('hidden');
            lucide.createIcons();
        }

        function openEditModal(button) {
            const data = button.dataset;
            const form = document.getElementById('productForm');
            form.reset();
            form.action = '/admin/san-pham/sua';

            setValue('ProductId', data.productId);
            setValue('CategoryId', data.categoryId);
            setValue('ProductCode', data.productCode);
            setValue('ProductName', data.productName);
            setValue('ProductType', data.productType);
            setValue('Brand', data.brand);
            setValue('Model', data.model);
            setValue('ShortDescription', data.shortDescription);
            setValue('Description', data.description);
            setValue('ThumbnailUrl', data.thumbnailUrl);
            setValue('Specifications', data.specifications);
            setValue('WarrantyMonths', data.warrantyMonths);
            setValue('CostPrice', data.costPrice);
            setValue('SalePrice', data.salePrice);
            setValue('StockQuantity', data.stockQuantity);
            setValue('ReorderLevel', data.reorderLevel);
            setValue('ImageUrl', data.imageUrl);
            document.getElementById('IsActive').checked = data.isActive === 'true';

            document.getElementById('modalTitle').textContent = 'Chỉnh sửa sản phẩm';
            document.getElementById('productModal').classList.remove('hidden');
            lucide.createIcons();
        }

        function setValue(id, value) {
            document.getElementById(id).value = value || '';
        }

        function closeModal() {
            document.getElementById('productModal').classList.add('hidden');
        }
    </script>
}
