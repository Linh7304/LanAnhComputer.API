@model List<LanAnhComputer.Dtos.CategoryDto>

@{
    ViewData["Title"] = "Quan ly danh muc";
    ViewData["ActivePage"] = "Categories";
    Layout = "_AdminLayout";
    var categories = Model ?? new List<LanAnhComputer.Dtos.CategoryDto>();
}

@if (TempData["Success"] != null)
{
    <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@TempData["Error"]</div>
}

<div class="flex items-center justify-between gap-4 mb-6">
    <div>
        <h2 class="text-lg font-semibold text-slate-800">Danh muc san pham</h2>
        <p class="text-sm text-slate-500 mt-1">Quan ly nhom san pham hien thi va gan cho san pham.</p>
    </div>
    <button type="button" onclick="openAddCategoryModal()" class="flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
        <i data-lucide="plus" class="w-4 h-4"></i>
        Them danh muc
    </button>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-slate-50">
                <tr>
                    <th class="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">Ma danh muc</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">Ten danh muc</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">Danh muc cha</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-slate-500 uppercase">Mo ta</th>
                    <th class="text-right px-6 py-3 text-xs font-medium text-slate-500 uppercase">Thao tac</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (!categories.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-slate-500">Chua co danh muc.</td>
                    </tr>
                }
                @foreach (var category in categories)
                {
                    var parentName = categories.FirstOrDefault(x => x.CategoryId == category.ParentCategoryId)?.CategoryName ?? "-";
                    <tr class="hover:bg-slate-50">
                        <td class="px-6 py-4 text-sm font-medium text-primary-600">@category.CategoryCode</td>
                        <td class="px-6 py-4 text-sm font-medium text-slate-800">@category.CategoryName</td>
                        <td class="px-6 py-4 text-sm text-slate-600">@parentName</td>
                        <td class="px-6 py-4 text-sm text-slate-600 max-w-md truncate">@category.Description</td>        
                        <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                                <button type="button"
                                        onclick="openEditCategoryModal(this)"
                                        class="p-2 hover:bg-slate-100 rounded-lg"
                                        title="Sua"
                                        data-category-id="@category.CategoryId"
                                        data-category-code="@category.CategoryCode"
                                        data-category-name="@category.CategoryName"
                                        data-parent-category-id="@category.ParentCategoryId"
                                        data-description="@category.Description">
                                    <i data-lucide="pencil" class="w-4 h-4 text-slate-500"></i>
                                </button>
                                <form method="post" action="/admin/danh-muc/xoa/@category.CategoryId" onsubmit="return confirm('Ban co chac muon xoa danh muc nay?')" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button class="p-2 hover:bg-red-100 rounded-lg" title="Xoa">
                                        <i data-lucide="trash-2" class="w-4 h-4 text-red-500"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="categoryModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" onclick="closeCategoryModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-xl bg-white rounded-2xl shadow-xl">
        <div class="flex items-center justify-between p-6 border-b border-slate-200">
            <h2 id="categoryModalTitle" class="text-xl font-semibold text-slate-800">Them danh muc</h2>
            <button type="button" onclick="closeCategoryModal()" class="p-2 hover:bg-slate-100 rounded-lg">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>

        <form id="categoryForm" method="post" action="/admin/danh-muc/them" class="p-6 space-y-4" onsubmit="return validateCategoryForm()">
            @Html.AntiForgeryToken()
            <input type="hidden" id="CategoryId" name="CategoryId" />

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Ma danh muc *</label>
                <input id="CategoryCode" name="CategoryCode" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Ten danh muc *</label>
                <input id="CategoryName" name="CategoryName" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Danh muc cha</label>
                <select id="ParentCategoryId" name="ParentCategoryId" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                    <option value="">-- Khong co --</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.CategoryId">@category.CategoryName</option>
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Mo ta</label>
                <textarea id="Description" name="Description" rows="3" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
            </div>
            <div id="categoryFormError" class="hidden rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-200">
                <button type="button" onclick="closeCategoryModal()" class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">Huy</button>
                <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">Luu danh muc</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddCategoryModal() {
            const form = document.getElementById('categoryForm');
            form.reset();
            form.action = '/admin/danh-muc/them';
            document.getElementById('CategoryId').value = '';
            document.getElementById('categoryModalTitle').textContent = 'Them danh muc';
            hideCategoryFormError();
            document.getElementById('categoryModal').classList.remove('hidden');
            lucide.createIcons();
        }

        function openEditCategoryModal(button) {
            const data = button.dataset;
            const form = document.getElementById('categoryForm');
            form.reset();
            form.action = '/admin/danh-muc/sua';

            setCategoryValue('CategoryId', data.categoryId);
            setCategoryValue('CategoryCode', data.categoryCode);
            setCategoryValue('CategoryName', data.categoryName);
            setCategoryValue('ParentCategoryId', data.parentCategoryId);
            setCategoryValue('Description', data.description);

            document.getElementById('categoryModalTitle').textContent = 'Sua danh muc';
            hideCategoryFormError();
            document.getElementById('categoryModal').classList.remove('hidden');
            lucide.createIcons();
        }

        function setCategoryValue(id, value) {
            document.getElementById(id).value = value || '';
        }

        function closeCategoryModal() {
            document.getElementById('categoryModal').classList.add('hidden');
        }

        function validateCategoryForm() {
            const categoryCode = document.getElementById('CategoryCode');
            const categoryName = document.getElementById('CategoryName');
            const categoryId = document.getElementById('CategoryId');
            const parentCategoryId = document.getElementById('ParentCategoryId');

            if (!categoryCode.value.trim()) {
                showCategoryFormError('Vui long nhap ma danh muc');
                categoryCode.focus();
                return false;
            }

            if (!categoryName.value.trim()) {
                showCategoryFormError('Vui long nhap ten danh muc');
                categoryName.focus();
                return false;
            }

            if (categoryId.value && parentCategoryId.value === categoryId.value) {
                showCategoryFormError('Danh muc cha khong duoc trung voi danh muc hien tai');
                parentCategoryId.focus();
                return false;
            }

            hideCategoryFormError();
            return true;
        }

        function showCategoryFormError(message) {
            const errorBox = document.getElementById('categoryFormError');
            errorBox.textContent = message;
            errorBox.classList.remove('hidden');
        }

        function hideCategoryFormError() {
            document.getElementById('categoryFormError').classList.add('hidden');
        }
    </script>
}
